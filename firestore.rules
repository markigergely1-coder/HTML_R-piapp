rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper függvény ───
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email.lower() in [
          'markigergely1@gmail.com',
          'annemaryaf@gmail.com'
        ];
    }

    // ─── Publikus kollekciók (bárki olvashatja, admin írhatja) ───
    // A profil + alkalmak + adatbázis oldal ezeket olvassa — nem-bejelentkezett
    // látogatók is láthatják.
    match /attendance_records/{doc} {
      allow read: if true;
      // Kis bizalmi csoport (kis röplabda csapat) — bárki (bejelentkezés nélkül is)
      // regisztrálhat, módosíthat, törölhet jelenléti rekordot.
      // Alapvető validáció create-nél, hogy ne lehessen szemét rekordokat felvinni.
      allow create: if request.resource.data.mode == 'valós'
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() < 100
        && request.resource.data.status in ['Yes', 'No']
        && request.resource.data.event_date is string;
      allow update: if true;
      allow delete: if true;
    }
    match /cancelled_sessions/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /members/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
    // QR check-in publikus — bárki regisztrálhat magát
    match /device_registrations/{doc} {
      allow read, write: if true;
    }

    // ─── Admin-only kollekciók ───
    match /invoices/{doc} {
      allow read, write: if isAdmin();
    }
    match /settlements/{doc} {
      allow read, write: if isAdmin();
    }
    match /app_logs/{doc} {
      allow read: if isAdmin();
      allow create: if request.auth != null && request.auth.token.email_verified == true;
      allow update, delete: if isAdmin();
    }
    match /revolut_name_mapping/{doc} {
      allow read, write: if isAdmin();
    }
    match /test_ping/{doc} {
      allow read, write: if isAdmin();
    }
    match /app_config/{doc} {
      allow read, write: if isAdmin();
    }

    // Historical / legacy kollekciók (Streamlit verzió hagyatéka) — nyilvános olvasás
    match /historical_session_totals/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /legacy_attendance/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
